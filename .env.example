# Clarion environment variables
# Copy to .env and fill in your server URLs.
# Edge TTS requires no configuration — it works immediately.

# Your self-hosted Kokoro server (optional)
# Docker Compose default: http://localhost:8880
# Hetzner/remote: https://your-server.example.com
KOKORO_SERVER=

# Your self-hosted Piper server (optional)
PIPER_SERVER=

# ElevenLabs API key (optional — required for ElevenLabs voices)
# Get one at: https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=

# Google Cloud TTS API key (optional — required for Google Chirp 3 HD voices)
# Get one at: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Cloud Text-to-Speech API
GOOGLE_TTS_API_KEY=

# Optional API key — if set, all requests must include Authorization: Bearer <key>
# Leave unset for open local access (default)
API_KEY=

# Restrict CORS to a specific origin (optional, defaults to *)
ALLOWED_ORIGIN=

# Rate limit /speak requests per minute per IP (optional, 0 = no limit)
# Example: RATE_LIMIT=20 allows 20 requests per minute per IP
RATE_LIMIT=

# For the Cloudflare Worker (wrangler dev / wrangler deploy),
# put these in server/.dev.vars instead:
#   KOKORO_SERVER=http://localhost:8880
#   PIPER_SERVER=http://localhost:5000

# UI — the URL of your deployed Clarion server
# Default: http://localhost:8787 (wrangler dev)
VITE_SERVER_URL=http://localhost:8787
