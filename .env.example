# Clarion environment variables
# Copy to .env and fill in your server URLs.
# Edge TTS requires no configuration — it works immediately.

# Your self-hosted Kokoro server (optional)
# Docker Compose default: http://localhost:8880
# Hetzner/remote: https://your-server.example.com
KOKORO_SERVER=

# Your self-hosted Piper server (optional)
PIPER_SERVER=

# For the Cloudflare Worker (wrangler dev / wrangler deploy),
# put these in server/.dev.vars instead:
#   KOKORO_SERVER=http://localhost:8880
#   PIPER_SERVER=http://localhost:5000

# UI — the URL of your deployed Clarion server
# Default: http://localhost:8787 (wrangler dev)
VITE_SERVER_URL=http://localhost:8787
