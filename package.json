{
  "name": "clarion",
  "version": "0.7.0",
  "description": "Give your AI agent a voice — self-hosted TTS proxy and voice manager",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/celanthe/clarion",
  "repository": {
    "type": "git",
    "url": "https://github.com/celanthe/clarion.git"
  },
  "keywords": [
    "tts",
    "text-to-speech",
    "ai-agent",
    "voice",
    "edge-tts",
    "kokoro",
    "piper",
    "elevenlabs",
    "self-hosted"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "cli/",
    "core/",
    "services/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "bin": {
    "clarion": "./cli/speak.js",
    "clarion-doctor": "./cli/doctor.js",
    "clarion-init": "./cli/init.js",
    "clarion-log": "./cli/log.js",
    "clarion-mute": "./cli/mute.js",
    "clarion-speak": "./cli/speak.js",
    "clarion-status": "./cli/status.js",
    "clarion-stream": "./cli/stream.js",
    "clarion-watch": "./cli/watch.js",
    "clarion-router": "./cli/router.js",
    "clarion-migrate": "./cli/migrate.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server:dev": "cd server && wrangler dev",
    "server:start": "cd server && node src/node-server.js",
    "server:deploy": "cd server && wrangler deploy",
    "test": "node test/hmac-auth.js"
  },
  "devDependencies": {
    "@fontsource/space-grotesk": "^5.2.10",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.0"
  }
}
